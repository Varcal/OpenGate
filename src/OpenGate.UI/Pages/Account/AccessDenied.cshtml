@page
@model OpenGate.UI.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
}

<div class="og-card">
    <div class="mb-5 flex items-center justify-center text-amber-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.981-1.742 2.981H4.419c-1.53 0-2.492-1.647-1.743-2.98l5.581-9.92zM11 13a1 1 0 10-2 0 1 1 0 002 0zm-1-7a1 1 0 00-.993.883L9 7v3a1 1 0 001.993.117L11 10V7a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
    </div>

    <h1 class="mb-3 text-center text-xl font-semibold text-gray-900 dark:text-gray-100">
        Você não tem permissão para acessar esta área
    </h1>

    <p class="text-center text-sm text-gray-600 dark:text-gray-400">
        O Admin UI requer um dos roles administrativos do OpenGate.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
    {
        <p class="mt-3 text-center text-xs text-gray-400 dark:text-gray-500">
            Recurso solicitado: <span class="font-mono">@Model.ReturnUrl</span>
        </p>
    }

    <div class="mt-6 space-y-3">
        <a href="/" class="og-btn-primary">Voltar ao início</a>
        <a href="/connect/logout" class="og-btn-secondary">Sair</a>
    </div>
</div>