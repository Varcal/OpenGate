@page
@model OpenGate.UI.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Criar conta";
}

<div class="og-card">
    <h1 class="mb-6 text-center text-xl font-semibold text-gray-900 dark:text-gray-100">
        Criar sua conta
    </h1>

    <div asp-validation-summary="ModelOnly" class="og-alert-error mb-5"></div>

    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />

        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label asp-for="Input.FirstName" class="og-label">Nome</label>
                    <input asp-for="Input.FirstName" type="text" autocomplete="given-name"
                           class="og-input" placeholder="João" />
                    <span asp-validation-for="Input.FirstName" class="og-field-error"></span>
                </div>
                <div>
                    <label asp-for="Input.LastName" class="og-label">Sobrenome</label>
                    <input asp-for="Input.LastName" type="text" autocomplete="family-name"
                           class="og-input" placeholder="Silva" />
                    <span asp-validation-for="Input.LastName" class="og-field-error"></span>
                </div>
            </div>

            <div>
                <label asp-for="Input.Email" class="og-label">E-mail</label>
                <input asp-for="Input.Email" type="email" autocomplete="email"
                       class="og-input" placeholder="voce@exemplo.com" />
                <span asp-validation-for="Input.Email" class="og-field-error"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="og-label">Senha</label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password"
                       class="og-input" placeholder="Mínimo 8 caracteres" />
                <span asp-validation-for="Input.Password" class="og-field-error"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword" class="og-label">Confirmar senha</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password"
                       class="og-input" placeholder="Repita a senha" />
                <span asp-validation-for="Input.ConfirmPassword" class="og-field-error"></span>
            </div>
        </div>

        <button type="submit" class="og-btn-primary mt-6">
            Criar conta
        </button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500 dark:text-gray-400">
        Já tem conta?
        <a href="/Account/Login@(Model.ReturnUrl != null ? "?returnUrl=" + Uri.EscapeDataString(Model.ReturnUrl) : "")"
           class="font-semibold text-primary-600 hover:text-primary-700
                  dark:text-primary-400 dark:hover:text-primary-300">
            Entrar
        </a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

