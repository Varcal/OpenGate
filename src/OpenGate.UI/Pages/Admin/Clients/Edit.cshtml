@page "{clientId}"
@model OpenGate.UI.Pages.Admin.Clients.EditModel
@{
    ViewData["Title"] = "Editar client";
}

<section class="space-y-6">
    <div class="og-page-header">
        <div>
            <h1 class="text-3xl font-semibold tracking-tight">Editar client</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Atualiza metadados, URIs, permissões e requirements do client.</p>
        </div>
        <a href="/Admin/Clients" class="og-btn-ghost">Voltar</a>
    </div>

    <form method="post" class="space-y-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 dark:text-red-300"></div>

        <div class="grid gap-4 lg:grid-cols-2">
            <div>
                <label asp-for="Input.ClientId" class="og-label">Client ID</label>
                <input asp-for="Input.ClientId" class="og-input" readonly />
            </div>
            <div>
                <label asp-for="Input.DisplayName" class="og-label">Display name</label>
                <input asp-for="Input.DisplayName" class="og-input" />
            </div>
            <div>
                <label asp-for="Input.ClientType" class="og-label">Client type</label>
                <select asp-for="Input.ClientType" class="og-input">
                    @foreach (var clientType in Model.SupportedClientTypes)
                    {
                        <option value="@clientType">@clientType</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Input.ConsentType" class="og-label">Consent type</label>
                <select asp-for="Input.ConsentType" class="og-input">
                    @foreach (var consentType in Model.SupportedConsentTypes)
                    {
                        <option value="@consentType">@consentType</option>
                    }
                </select>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.ClientSecret" class="og-label">Novo client secret</label>
                <input asp-for="Input.ClientSecret" class="og-input" />
                <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Deixe em branco para manter o segredo atual.</p>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.RedirectUris" class="og-label">Redirect URIs</label>
                <textarea asp-for="Input.RedirectUris" rows="4" class="og-input"></textarea>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.PostLogoutRedirectUris" class="og-label">Post logout redirect URIs</label>
                <textarea asp-for="Input.PostLogoutRedirectUris" rows="3" class="og-input"></textarea>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.Permissions" class="og-label">Permissions</label>
                <textarea asp-for="Input.Permissions" rows="6" class="og-input"></textarea>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.Requirements" class="og-label">Requirements</label>
                <textarea asp-for="Input.Requirements" rows="3" class="og-input"></textarea>
            </div>
        </div>

        <div class="flex flex-wrap justify-end gap-3">
            <a href="/Admin/Clients" class="og-btn-ghost">Cancelar</a>
            <button type="submit" class="og-btn-action">Salvar alterações</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
