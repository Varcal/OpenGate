@using System.Security.Claims
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var display = User.Identity?.Name ?? User.FindFirst(ClaimTypes.Email)?.Value ?? "Administrador";
    var roles = User.FindAll(ClaimTypes.Role).Select(c => c.Value).Distinct(StringComparer.Ordinal).ToArray();
    var pageTitle = ViewData["Title"] as string ?? "Admin";
    var statusMessage = TempData["StatusMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;

    // Avatar initial
    var initial = display.Length > 0 ? display[..1].ToUpper() : "A";

    bool IsActive(string path)
    {
        if (string.Equals(path, "/Admin", StringComparison.OrdinalIgnoreCase))
            return string.Equals(currentPage, "/Admin", StringComparison.OrdinalIgnoreCase)
                || string.Equals(currentPage, "/Admin/Index", StringComparison.OrdinalIgnoreCase);
        return currentPage.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    string NavClass(string path) => IsActive(path) ? "og-nav-item-active" : "og-nav-item";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>@(pageTitle != null ? $"{pageTitle} — " : string.Empty)OpenGate Admin</title>
    <link rel="stylesheet" href="~/_content/OpenGate.UI/css/opengate.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="h-full overflow-hidden">

    <script>
        (function () {
            const stored = localStorage.getItem('og-theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (stored === 'dark' || (!stored && prefersDark)) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>

    <div class="flex h-full bg-gray-100 dark:bg-gray-950">

        <!-- ── Mobile sidebar overlay ─────────────────────────────── -->
        <div id="sidebar-overlay"
             class="fixed inset-0 z-20 hidden bg-black/60 backdrop-blur-sm lg:hidden"
             onclick="closeSidebar()"></div>

        <!-- ── Sidebar ──────────────────────────────────────────────── -->
        <aside id="sidebar"
               class="fixed inset-y-0 left-0 z-30 flex w-64 shrink-0 -translate-x-full flex-col
                      bg-gray-950 transition-transform duration-200 lg:static lg:translate-x-0">

            <!-- Brand -->
            <div class="flex h-16 shrink-0 items-center gap-3 border-b border-white/10 px-5">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg
                            bg-primary-600 text-white shadow-sm ring-1 ring-primary-500/40">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold leading-none text-white">OpenGate</p>
                    <p class="mt-0.5 text-xs text-gray-500">Admin Console</p>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
                <p class="mb-1.5 px-3 text-[10px] font-semibold uppercase tracking-widest text-gray-600">Geral</p>

                <a href="/Admin" class="@NavClass("/Admin")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                    </svg>
                    Visão geral
                </a>

                <p class="mb-1.5 mt-5 px-3 text-[10px] font-semibold uppercase tracking-widest text-gray-600">Identidade</p>

                <a href="/Admin/Users" class="@NavClass("/Admin/Users")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Usuários
                </a>

                <a href="/Admin/Clients" class="@NavClass("/Admin/Clients")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    </svg>
                    Clients
                </a>

                <a href="/Admin/Scopes" class="@NavClass("/Admin/Scopes")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                    </svg>
                    Scopes
                </a>

                <p class="mb-1.5 mt-5 px-3 text-[10px] font-semibold uppercase tracking-widest text-gray-600">Auditoria</p>

                <a href="/Admin/Sessions" class="@NavClass("/Admin/Sessions")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    Sessões
                </a>

                <a href="/Admin/AuditLogs" class="@NavClass("/Admin/AuditLogs")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    Audit logs
                </a>

                <!-- Developer tools -->
                <p class="mb-1.5 mt-5 px-3 text-[10px] font-semibold uppercase tracking-widest text-gray-600">Developer</p>
                <a href="/docs" class="og-nav-item" target="_blank" rel="noopener">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    API Docs
                    <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto h-3 w-3 text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                </a>
            </nav>

            <!-- User footer -->
            <div class="shrink-0 border-t border-white/10 p-3">
                <div class="flex items-center gap-2.5 rounded-xl px-2 py-2.5">
                    <!-- Avatar -->
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full
                                bg-primary-600/20 text-sm font-semibold text-primary-400">
                        @initial
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="truncate text-xs font-semibold text-gray-200">@display</p>
                        <div class="mt-0.5 flex flex-wrap gap-x-1.5">
                            @foreach (var role in roles)
                            {
                                <span class="text-[10px] font-medium text-gray-500">@role</span>
                            }
                        </div>
                    </div>
                    <!-- Actions -->
                    <div class="flex shrink-0 items-center">
                        <button onclick="toggleTheme()" id="theme-btn"
                                class="flex h-7 w-7 items-center justify-center rounded-md text-gray-600
                                       transition-colors hover:bg-white/5 hover:text-gray-300"
                                title="Alternar tema">
                            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="5"/>
                                <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                            </svg>
                            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </button>
                        <a href="/connect/logout"
                           class="flex h-7 w-7 items-center justify-center rounded-md text-gray-600
                                  transition-colors hover:bg-white/5 hover:text-gray-300"
                           title="Sair">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <!-- ── Main area ───────────────────────────────────────────── -->
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">

            <!-- Top bar -->
            <header class="flex h-14 shrink-0 items-center gap-3 border-b border-gray-200
                           bg-white px-4 dark:border-gray-800 dark:bg-gray-900 lg:px-6">
                <!-- Mobile hamburger -->
                <button onclick="openSidebar()"
                        class="flex h-8 w-8 items-center justify-center rounded-lg text-gray-500
                               hover:bg-gray-100 dark:hover:bg-gray-800 lg:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>

                <div class="flex-1 min-w-0">
                    <p class="truncate text-sm font-semibold text-gray-800 dark:text-gray-200">@pageTitle</p>
                </div>

                <div class="flex items-center">
                    <a href="/openapi/v1.json"
                       class="hidden items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-xs font-medium
                              text-gray-500 hover:bg-gray-100 hover:text-gray-700
                              dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200 sm:flex"
                       title="OpenAPI JSON" target="_blank" rel="noopener">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                        </svg>
                        OpenAPI
                    </a>
                </div>
            </header>

            <!-- Scrollable content -->
            <main class="flex-1 overflow-y-auto bg-gray-50 dark:bg-gray-950">

                @if (!string.IsNullOrWhiteSpace(statusMessage) || !string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="mx-auto max-w-7xl px-4 pt-5 lg:px-6">
                        @if (!string.IsNullOrWhiteSpace(statusMessage))
                        {
                            <div class="mb-3 flex items-center gap-3 rounded-xl border border-emerald-200
                                        bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm
                                        dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                @statusMessage
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <div class="mb-3 flex items-center gap-3 rounded-xl border border-red-200
                                        bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm
                                        dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16.01"/>
                                </svg>
                                @errorMessage
                            </div>
                        }
                    </div>
                }

                <div class="mx-auto max-w-7xl px-4 py-6 lg:px-6">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script>
        function updateThemeIcon() {
            const isDark = document.documentElement.classList.contains('dark');
            const sun = document.getElementById('icon-sun');
            const moon = document.getElementById('icon-moon');
            if (sun && moon) {
                sun.classList.toggle('hidden', !isDark);
                moon.classList.toggle('hidden', isDark);
            }
        }
        function toggleTheme() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('og-theme', isDark ? 'dark' : 'light');
            updateThemeIcon();
        }
        function openSidebar() {
            document.getElementById('sidebar').classList.remove('-translate-x-full');
            document.getElementById('sidebar-overlay').classList.remove('hidden');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.add('-translate-x-full');
            document.getElementById('sidebar-overlay').classList.add('hidden');
        }
        updateThemeIcon();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
